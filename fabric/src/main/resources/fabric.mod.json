{
  "schemaVersion": 1,
  "id": "reaperac",
  "version": "${version}",
  "name": "ReaperAC",
  "description": "Libre simulation anticheat designed for 1.21 with 1.8-1.21 support, powered by PacketEvents 2.0.",
  "authors": [
    "ReaperAC"
  ],
  "license": "GPLv3",
  "environment": "server",
  "entrypoints": {
    "main": [
      "ac.reaper.reaperac.platform.fabric.GrimACFabricEntryPoint"
    ],
    "preLaunch": [
      "ac.reaper.reaperac.platform.fabric.GrimACFabricEntryPoint"
    ],
    "grimMainLoad": [
      "ac.reaper.reaperac.platform.fabric.mc262.GrimACFabric262LoaderPlugin"
    ]
  },
  "mixins": [
    "grimac.mixins.json"
  ],
  "custom": {
    "loom:injected_interfaces": {
      "net/minecraft/world/level/Level": [
        "ac/reaper/reaperac/platform/api/world/PlatformWorld"
      ]
    }
  },
  "accessWidener": "grimac.accesswidener",
  "depends": {
    "fabricloader": "\u003e\u003d0.19.1",
    "fabric-lifecycle-events-v1": "*",
    "packetevents": ">=2.12.0",
    "minecraft": "\u003e\u003d26.2-alpha.1"
  },
  "recommends": {
    "cloud": "*",
    "fabric-permissions-api-v0": "*"
  }
}
